# Copy this file to `.env` and fill in your own API keys.
# `.env` is gitignored — never commit real keys.

# OpenAI (GPT-4o, o3-mini, ...)
OPENAI_API_KEY=

# Anthropic (Claude) — optional, only if you grade or evaluate with Anthropic models
ANTHROPIC_API_KEY=

# Google (Gemini) — optional
GOOGLE_API_KEY=

# GWDG Chat AI — German open-source models via the Göttingen academic compute cluster.
# Request access at https://docs.hpc.gwdg.de/services/chat-ai/index.html
GWDG_API_KEY=
GWDG_BASE_URL=

# Arcana RAG knowledge base used by _run_gwdg_models.py.
# Default: the German Betriebsverfassungsgesetz (Works Constitution Act).
GWDG_ARCANA_ID=ananyapam.de01/Betriebsverfassungsgesetz

# Store Inspect AI logs under data/logs (keeps all artefacts under data/).
INSPECT_LOG_DIR=data/logs

# GitHub Copilot API — optional grader path for users without an ANTHROPIC_API_KEY and with a github education account and activated developer pack.
# scripts/_copilot_proxy.py handles the OAuth → bearer flow + IDE headers locally.
COPILOT_OAUTH=
COPILOT_PROXY_PORT=8765
COPILOT_API_KEY=unused-placeholder
COPILOT_BASE_URL=http://localhost:8765/v1
